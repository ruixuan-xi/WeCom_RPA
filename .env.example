# 企业微信通用配置（三个服务都需要）
WECOM_TOKEN=your_wecom_callback_token
WECOM_ENCODING_AES_KEY=your_43_char_encoding_aes_key
WECOM_CORP_ID=your_corp_id

# 微信客服专用配置（仅 wx_wxkf.py 需要）
WECOM_KF_SECRET=your_kf_app_secret
WECOM_OPEN_KFID=your_open_kfid

# 影刀 RPA Webhook 地址
RPA_ROBOT_WEBHOOK_URL=https://your-yingdao-webhook-url
RPA_KF_WEBHOOK_URL=https://your-yingdao-kf-webhook-url

# 可选配置
ROBOT_PORT=5000
KF_PORT=8887
VERIFY_PORT=5000
FLASK_DEBUG=false
KF_CURSOR_FILE=kf_cursor.txt
